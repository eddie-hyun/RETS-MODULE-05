{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rets-requirement-schema",
  "title": "RETS 요구사항 스키마",
  "description": "Requirements Engineering Tool Suite — 요구사항 데이터 모델 정의 (RFP 요구사항 / 개발 요구사항)",
  "version": "3.0.0",

  "definitions": {

    "enums": {

      "ReqType": {
        "type": "string",
        "enum": ["RFP", "DEV"],
        "description": "요구사항 문서 구분 — RFP 요구사항(RFP) 또는 개발 요구사항(DEV)"
      },

      "ReqLevel": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5,
        "description": "요구사항 수준 — req_id의 계층 깊이와 반드시 일치해야 한다.\n  level = (SEQ 이후의 _XX 구성요소 수) + 1\n  1(업무영역/Epic) ~ 5(명세항목/Sub-task)\n  일반 프로젝트: 업무영역 → 기능집합 → 기능 → 세부기능 → 명세항목\n  애자일 프로젝트: Epic → Feature → User Story → Task → Sub-task"
      },

      "FunctionalClass": {
        "type": "string",
        "enum": ["기능", "비기능"],
        "description": "기능 요구사항(FR) / 비기능 요구사항(NFR) 구분\n  DEV 요구사항의 경우 req_id 프리픽스(FR/NFR)와 반드시 일치해야 함"
      },

      "ReqCategory": {
        "type": "string",
        "enum": [
          "기능",
          "인터페이스",
          "데이터",
          "배치",
          "성능",
          "보안",
          "가용성",
          "유지보수성",
          "운영",
          "제약사항",
          "기타"
        ],
        "description": "요구사항 유형 — 기능/비기능의 세부 분류"
      },

      "DomainArea": {
        "type": "string",
        "enum": [
          "UI/UX",
          "인증/인가",
          "데이터관리",
          "통합/인터페이스",
          "AI/LLM",
          "성능",
          "보안",
          "운영",
          "인프라",
          "공통",
          "기타"
        ],
        "description": "도메인 영역 — 요구사항이 속하는 업무/기술 도메인 (참조·분류 용도, ID에는 포함하지 않음)"
      },

      "VerificationMethod": {
        "type": "string",
        "enum": ["테스트", "검사", "분석", "시연", "검토"],
        "description": "검증 방법 — IEEE 829 기반의 V&V 방법론 분류\n  테스트: 테스트케이스 실행으로 확인 | 검사: 산출물/코드 직접 확인\n  분석: 수치·데이터 분석으로 확인 | 시연: 기능 시연을 통해 확인 | 검토: 전문가 검토/리뷰로 확인"
      },

      "Priority": {
        "type": "string",
        "enum": ["MUST", "SHOULD", "COULD", "WONT"],
        "description": "MoSCoW 우선순위\n  MUST: 필수 구현 | SHOULD: 가능하면 구현 | COULD: 여유 시 구현 | WONT: 이번 범위 제외"
      },

      "Importance": {
        "type": "string",
        "enum": ["Critical", "High", "Medium", "Low"],
        "description": "중요도 — 비즈니스/운영 관점에서 요구사항의 중요성"
      },

      "ReqStatus": {
        "type": "string",
        "enum": ["Draft", "InReview", "Approved", "Rejected", "Deferred", "Deprecated"],
        "description": "요구사항 상태\n  Draft: 초안 | InReview: 검토 중 | Approved: 승인됨 | Rejected: 반려됨 | Deferred: 보류 | Deprecated: 폐기"
      },

      "AcceptanceStatus": {
        "type": "string",
        "enum": ["수용", "조건부수용", "불수용", "검토중", "해당없음"],
        "description": "[RFP 전용] RFP 기준 수용 여부\n  수용: 요구사항 그대로 수용 | 조건부수용: 조건·협의 후 수용 | 불수용: 수용 불가\n  검토중: 수용 여부 미결 | 해당없음: 수용 여부 판단 불필요"
      },

      "DevStatus": {
        "type": "string",
        "enum": ["Todo", "InProgress", "Done", "Blocked", "Skipped"],
        "description": "[DEV 전용] 개발 진행 상태\n  Todo: 미착수 | InProgress: 진행 중 | Done: 완료 | Blocked: 차단됨 | Skipped: 건너뜀"
      }
    },

    "types": {

      "ChangeHistoryEntry": {
        "type": "object",
        "required": ["version", "date", "author", "description"],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
            "description": "변경 후 버전 (예: 1.1, 1.2.0)"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "변경일 (ISO 8601, 예: 2026-05-04)"
          },
          "author": {
            "type": "string",
            "description": "변경 작성자"
          },
          "description": {
            "type": "string",
            "description": "변경 내용 요약"
          },
          "changed_fields": {
            "type": "array",
            "items": { "type": "string" },
            "description": "변경된 필드명 목록 (선택)"
          }
        },
        "additionalProperties": false
      },

      "IOSpec": {
        "type": "object",
        "properties": {
          "inputs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "입력 항목 목록"
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "출력 항목 목록"
          }
        },
        "additionalProperties": false,
        "description": "[DEV 전용] 입력/출력 명세"
      }
    }
  },

  "schemas": {

    "CommonFields": {
      "description": "RFP 요구사항과 개발 요구사항에 공통으로 적용되는 필드 정의",
      "type": "object",
      "required": [
        "req_type",
        "req_id",
        "req_version",
        "req_level",
        "req_name",
        "functional_class",
        "req_category",
        "description",
        "req_status",
        "created_by",
        "last_modified_date"
      ],
      "properties": {

        "req_type": {
          "$ref": "#/definitions/enums/ReqType",
          "description": "[공통] RFP/DEV 구분"
        },

        "req_level": {
          "$ref": "#/definitions/enums/ReqLevel",
          "description": "[공통] 요구사항 수준 (1~5) — req_id의 계층 깊이와 반드시 일치"
        },

        "req_id": {
          "type": "string",
          "pattern": "^(RFP|DEV_(FR|NFR))_\\d{3}(_\\d{2}){0,4}$",
          "examples": [
            "RFP_001",
            "RFP_001_01",
            "RFP_001_01_03",
            "RFP_001_01_03_11",
            "RFP_001_01_03_11_07",
            "DEV_FR_317",
            "DEV_FR_317_01",
            "DEV_FR_317_01_03",
            "DEV_FR_317_01_03_11",
            "DEV_FR_317_01_03_11_07",
            "DEV_NFR_023",
            "DEV_NFR_023_11",
            "DEV_NFR_023_11_04"
          ],
          "description": "[공통] 요구사항 ID — 채번 규칙 및 계층 규칙 준수 필수\n\n  형식: {PREFIX}_{SEQ}[_{L2}[_{L3}[_{L4}[_{L5}]]]]\n  PREFIX : RFP | DEV_FR | DEV_NFR\n  SEQ   : 3자리 일련번호 (001~999, PREFIX 내 독립 채번)\n  Ln    : 각 계층의 2자리 하위 번호 (01~99)\n\n  ★ 계층 깊이(Depth) = req_level 과 반드시 일치해야 한다.\n  level 1 → SEQ만 존재             (예: DEV_FR_317)\n  level 2 → SEQ + L2               (예: DEV_FR_317_01)\n  level 3 → SEQ + L2 + L3          (예: DEV_FR_317_01_03)\n  level 4 → SEQ + L2 + L3 + L4     (예: DEV_FR_317_01_03_11)\n  level 5 → SEQ + L2 + L3 + L4 + L5 (예: DEV_FR_317_01_03_11_07)\n\n  상위 ID는 하위 ID에 완전히 포함된다.\n  DEV_FR_317_01 의 부모는 DEV_FR_317 이다."
        },

        "req_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
          "default": "1.0",
          "examples": ["1.0", "1.1", "2.0.1"],
          "description": "[공통] 요구사항 버전 (Semantic Versioning 간소화)"
        },

        "req_name": {
          "type": "string",
          "maxLength": 200,
          "description": "[공통] 요구사항명 — 명확하고 간결한 한 문장"
        },

        "functional_class": {
          "$ref": "#/definitions/enums/FunctionalClass",
          "description": "[공통] 기능/비기능 구분 (DEV 요구사항은 req_id의 FR/NFR 프리픽스와 일치해야 함)"
        },

        "req_category": {
          "$ref": "#/definitions/enums/ReqCategory",
          "description": "[공통] 요구사항 유형 (기능, 인터페이스, 배치 등)"
        },

        "domain_area": {
          "$ref": "#/definitions/enums/DomainArea",
          "description": "[공통] 도메인 영역 (참조·분류 용도)"
        },

        "description": {
          "type": "string",
          "description": "[공통] 요구사항 설명 (상세 내용)"
        },

        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string" },
          "description": "[공통] 완료 기준 — 요구사항이 충족되었음을 판단하는 조건 목록"
        },

        "verification_method": {
          "$ref": "#/definitions/enums/VerificationMethod",
          "description": "[공통] 검증 방법"
        },

        "metrics": {
          "type": "array",
          "items": { "type": "string" },
          "description": "[공통] 측정 지표 — 수치로 검증 가능한 기준 (예: '응답시간 < 2초')"
        },

        "priority": {
          "$ref": "#/definitions/enums/Priority",
          "description": "[공통] 우선순위 (MoSCoW)"
        },

        "importance": {
          "$ref": "#/definitions/enums/Importance",
          "description": "[공통] 중요도"
        },

        "stakeholders": {
          "type": "array",
          "items": { "type": "string" },
          "description": "[공통] 연관 이해관계자 (역할명 또는 담당자명)"
        },

        "created_by": {
          "type": "string",
          "description": "[공통] 발의자 (요구사항 최초 작성·등록자)"
        },

        "last_modified_date": {
          "type": "string",
          "format": "date",
          "description": "[공통] 최종수정일 (ISO 8601, 예: 2026-05-04)"
        },

        "req_status": {
          "$ref": "#/definitions/enums/ReqStatus",
          "description": "[공통] 요구사항 상태"
        },

        "manager": {
          "type": "string",
          "description": "[공통] 관리 담당자 (요구사항 라이프사이클 관리 책임자)"
        },

        "reviewer": {
          "type": "string",
          "description": "[공통] 검토자"
        },

        "change_history": {
          "type": "array",
          "items": { "$ref": "#/definitions/types/ChangeHistoryEntry" },
          "description": "[공통] 변경이력 — 버전별 변경 사유·내용 기록"
        }
      }
    },

    "RFPRequirement": {
      "description": "RFP 요구사항 스키마 — 공통 필드 + RFP 전용 필드\n  req_id 패턴: ^RFP_\\d{3}(_\\d{2}){0,4}$\n  계층 깊이는 req_level과 일치 (level1=깊이0, level5=깊이4)",
      "allOf": [
        { "$ref": "#/schemas/CommonFields" },
        {
          "type": "object",
          "required": ["acceptance_status"],
          "properties": {

            "req_type": {
              "const": "RFP",
              "description": "[식별자] RFP 요구사항 고정값"
            },

            "req_id": {
              "type": "string",
              "pattern": "^RFP_\\d{3}(_\\d{2}){0,4}$",
              "examples": [
                "RFP_001",
                "RFP_001_01",
                "RFP_001_01_03",
                "RFP_001_01_03_11",
                "RFP_001_01_03_11_07"
              ],
              "description": "[RFP] 요구사항 ID — 레벨별 형식\n  level 1: RFP_{SEQ}\n  level 2: RFP_{SEQ}_{L2}\n  level 3: RFP_{SEQ}_{L2}_{L3}\n  level 4: RFP_{SEQ}_{L2}_{L3}_{L4}\n  level 5: RFP_{SEQ}_{L2}_{L3}_{L4}_{L5}"
            },

            "acceptance_status": {
              "$ref": "#/definitions/enums/AcceptanceStatus",
              "description": "[RFP 전용] 수용여부 — RFP 기준 수용 검토 결과"
            }
          }
        }
      ]
    },

    "DevRequirement": {
      "description": "개발 요구사항 스키마 — 공통 필드 + DEV 전용 필드\n  req_id 패턴: ^DEV_(FR|NFR)_\\d{3}(_\\d{2}){0,4}$\n  계층 깊이는 req_level과 일치 (level1=깊이0, level5=깊이4)\n  FR: 기능 요구사항 (functional_class='기능')\n  NFR: 비기능 요구사항 (functional_class='비기능')",
      "allOf": [
        { "$ref": "#/schemas/CommonFields" },
        {
          "type": "object",
          "properties": {

            "req_type": {
              "const": "DEV",
              "description": "[식별자] 개발 요구사항 고정값"
            },

            "req_id": {
              "type": "string",
              "pattern": "^DEV_(FR|NFR)_\\d{3}(_\\d{2}){0,4}$",
              "examples": [
                "DEV_FR_317",
                "DEV_FR_317_01",
                "DEV_FR_317_01_03",
                "DEV_FR_317_01_03_11",
                "DEV_FR_317_01_03_11_07",
                "DEV_NFR_023",
                "DEV_NFR_023_11",
                "DEV_NFR_023_11_04"
              ],
              "description": "[DEV] 요구사항 ID — 레벨별 형식\n  level 1: DEV_FR_{SEQ}  / DEV_NFR_{SEQ}\n  level 2: DEV_FR_{SEQ}_{L2}  / DEV_NFR_{SEQ}_{L2}\n  level 3: DEV_FR_{SEQ}_{L2}_{L3}  / DEV_NFR_{SEQ}_{L2}_{L3}\n  level 4: DEV_FR_{SEQ}_{L2}_{L3}_{L4}  / DEV_NFR_{SEQ}_{L2}_{L3}_{L4}\n  level 5: DEV_FR_{SEQ}_{L2}_{L3}_{L4}_{L5} / DEV_NFR_{SEQ}_{L2}_{L3}_{L4}_{L5}"
            },

            "io_spec": {
              "$ref": "#/definitions/types/IOSpec",
              "description": "[DEV 전용] 입력/출력 명세"
            },

            "story_points": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "examples": [1, 2, 3, 5, 8, 13],
              "description": "[DEV 전용] 스토리포인트 — 상대적 구현 복잡도 (피보나치 수열 권장)"
            },

            "estimated_effort": {
              "type": "number",
              "minimum": 0,
              "examples": [0.5, 1.0, 2.0, 5.0],
              "description": "[DEV 전용] 예상공수 (단위: MD, Man-Day)"
            },

            "source_rfp_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^RFP_\\d{3}(_\\d{2}){0,4}$"
              },
              "examples": [["RFP_001", "RFP_001_01"]],
              "description": "[DEV 전용] 근거 RFP 요구사항 ID 목록 — 이 DEV 요구사항이 도출된 RFP 요구사항 참조"
            },

            "predecessor_dev_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^DEV_(FR|NFR)_\\d{3}(_\\d{2}){0,4}$"
              },
              "examples": [["DEV_FR_001"]],
              "description": "[DEV 전용] 선행 개발요구사항 ID 목록 — 이 요구사항 착수 전 완료되어야 하는 선행 DEV 요구사항"
            },

            "dev_status": {
              "$ref": "#/definitions/enums/DevStatus",
              "description": "[DEV 전용] 개발 진행 상태"
            },

            "developer": {
              "type": "string",
              "description": "[DEV 전용] 개발 담당자"
            }
          }
        }
      ]
    },

    "Requirement": {
      "description": "통합 요구사항 스키마 — req_type 값에 따라 RFPRequirement 또는 DevRequirement로 분기",
      "oneOf": [
        { "$ref": "#/schemas/RFPRequirement" },
        { "$ref": "#/schemas/DevRequirement" }
      ],
      "discriminator": {
        "propertyName": "req_type"
      }
    }
  },

  "examples": {
    "hierarchy_rfp": {
      "comment": "RFP 요구사항 — 5단계 계층 예시 (부모→자식 순, 동일 트리)",
      "level_1": { "req_id": "RFP_001",             "req_level": 1, "req_name": "사용자 인터페이스 제공" },
      "level_2": { "req_id": "RFP_001_01",          "req_level": 2, "req_name": "테마 전환 기능" },
      "level_3": { "req_id": "RFP_001_01_03",       "req_level": 3, "req_name": "라이트/다크 모드 전환 지원" },
      "level_4": { "req_id": "RFP_001_01_03_11",    "req_level": 4, "req_name": "다크 모드 색상 토큰 정의" },
      "level_5": { "req_id": "RFP_001_01_03_11_07", "req_level": 5, "req_name": "다크 모드 포인트 컬러 가독성 기준" }
    },
    "hierarchy_dev_fr": {
      "comment": "DEV 기능 요구사항 — 5단계 계층 예시 (부모→자식 순, 동일 트리)",
      "level_1": { "req_id": "DEV_FR_317",             "req_level": 1, "req_name": "UI 테마 시스템 구현" },
      "level_2": { "req_id": "DEV_FR_317_01",          "req_level": 2, "req_name": "CSS 토큰 기반 테마 전환 구현" },
      "level_3": { "req_id": "DEV_FR_317_01_03",       "req_level": 3, "req_name": "data-theme 속성 기반 다크 모드 적용" },
      "level_4": { "req_id": "DEV_FR_317_01_03_11",    "req_level": 4, "req_name": "localStorage를 통한 테마 선택 유지" },
      "level_5": { "req_id": "DEV_FR_317_01_03_11_07", "req_level": 5, "req_name": "초기 로드 시 저장된 테마 값 복원 처리" }
    },
